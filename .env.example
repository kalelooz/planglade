# Public self-host defaults: SQLite, NextAuth, and local attachment storage.
DATABASE_URL="file:../db/custom.db"
FLOWBOARD_AUTH_MODE="nextauth"
NEXT_PUBLIC_FLOWBOARD_AUTH_MODE="nextauth"
FLOWBOARD_STORAGE_PROVIDER="local"

# NextAuth requires a stable secret and at least one OAuth provider.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-value"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
# GITHUB_ID="your-github-oauth-client-id"
# GITHUB_SECRET="your-github-oauth-client-secret"

# Optional local attachment storage overrides.
# FLOWBOARD_LOCAL_STORAGE_DIR="storage/local-attachments"
# FLOWBOARD_STORAGE_SIGNING_SECRET="replace-with-a-long-random-value"

# Optional Firebase compatibility mode. Firebase is never required for self-hosting.
# FLOWBOARD_AUTH_MODE="firebase"
# NEXT_PUBLIC_FLOWBOARD_AUTH_MODE="firebase"
# FLOWBOARD_STORAGE_PROVIDER="firebase"
# NEXT_PUBLIC_FIREBASE_API_KEY="your-public-api-key"
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
# NEXT_PUBLIC_FIREBASE_APP_ID="your-firebase-app-id"
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_PRIVATE_KEY_BASE64="base64-encoded-private-key"

# Optional development-only session scaffold.
# FLOWBOARD_AUTH_MODE="dev"
# NEXT_PUBLIC_FLOWBOARD_AUTH_MODE="dev"
