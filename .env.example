# Copy this file to .env. Never commit .env or paste its values into logs.
# Public standalone PlanGlade requires Node.js 22.5+ when run without Docker.

DATABASE_URL="file:../db/custom.db"

# Local development auth and storage. Dev auth is never for public exposure.
PLANGLADE_AUTH_MODE="dev"
NEXT_PUBLIC_PLANGLADE_AUTH_MODE="dev"
PLANGLADE_STORAGE_PROVIDER="local"
PLANGLADE_LOCAL_STORAGE_DIR="storage/local-attachments"
PLANGLADE_STORAGE_SIGNING_SECRET="replace-with-a-random-local-secret"

# Set only on a dedicated public demo deployment. Mutations become read-only.
# PLANGLADE_DEMO_READ_ONLY="true"

# Optional local development workspace labels.
PLANGLADE_WORKSPACE_SLUG="dev-workspace"
PLANGLADE_WORKSPACE_NAME="PlanGlade Dev Workspace"

# ---------------------------------------------------------------------------
# Docker Compose public standalone baseline.
# ---------------------------------------------------------------------------
# Docker runs without Firebase and does not require OAuth. Compose supplies
# NextAuth mode, SQLite at /app/db/planglade.db, and local attachments at
# /app/storage/local-attachments. Replace every active placeholder.
PLANGLADE_PORT="3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-nextauth-secret"

# Supported no-OAuth sign-in and one-time first OWNER setup.
PLANGLADE_LOCAL_AUTH_ENABLED="true"
PLANGLADE_SETUP_TOKEN="replace-with-a-separate-one-time-random-setup-token"
# Remove PLANGLADE_SETUP_TOKEN after setup completes and recreate the app.

# Optional dedicated persistent abuse-control subject key.
# If unset, NEXTAUTH_SECRET is used.
# PLANGLADE_THROTTLE_SECRET="replace-with-a-dedicated-random-secret"

# Optional dedicated local attachment URL signing key.
# If unset, docker-compose.yml uses NEXTAUTH_SECRET.
# PLANGLADE_STORAGE_SIGNING_SECRET="replace-with-a-dedicated-random-secret"

# Compose already sets these values for the public standalone app.
# PLANGLADE_AUTH_MODE="nextauth"
# NEXT_PUBLIC_PLANGLADE_AUTH_MODE="nextauth"

# Optional OAuth providers. Local credentials work without them.
# GITHUB_ID="replace-with-github-client-id"
# GITHUB_SECRET="replace-with-github-client-secret"
# GOOGLE_CLIENT_ID="replace-with-google-client-id"
# GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Invite email is disabled by default. Password recovery never uses email.
# PLANGLADE_EMAIL_PROVIDER="disabled"
# Optional production invite delivery via Resend:
# PLANGLADE_EMAIL_PROVIDER="resend"
# PLANGLADE_EMAIL_FROM="PlanGlade <invites@example.com>"
# RESEND_API_KEY="replace-with-resend-api-key"

# Maintenance job token for the invite-expiry endpoint.
# PLANGLADE_MAINTENANCE_TOKEN="replace-with-random-maintenance-token"
