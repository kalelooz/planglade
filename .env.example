# Copy this file to .env for local development.
# Never commit .env. Keep real secrets, tokens, database URLs, and private keys out of git.

DATABASE_URL="file:../db/custom.db"

# Local development auth and storage.
# Do not use dev auth for a public/production deployment.
FLOWBOARD_AUTH_MODE="dev"
NEXT_PUBLIC_FLOWBOARD_AUTH_MODE="dev"
FLOWBOARD_STORAGE_PROVIDER="local"
FLOWBOARD_LOCAL_STORAGE_DIR="storage/local-attachments"
FLOWBOARD_STORAGE_SIGNING_SECRET="replace-with-a-random-local-secret"

# Optional dev workspace seed labels.
FLOWBOARD_WORKSPACE_SLUG="dev-workspace"
FLOWBOARD_WORKSPACE_NAME="PlanGlade Dev Workspace"

# Firebase auth/storage mode placeholders.
# Use only fake values here. Put real Firebase values in .env or your deployment secret store.
# FLOWBOARD_AUTH_MODE="firebase"
# NEXT_PUBLIC_FLOWBOARD_AUTH_MODE="firebase"
# FLOWBOARD_STORAGE_PROVIDER="firebase"
# NEXT_PUBLIC_FIREBASE_API_KEY="replace-with-public-firebase-api-key"
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="replace-with-sender-id"
# NEXT_PUBLIC_FIREBASE_APP_ID="replace-with-firebase-app-id"
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-placeholder@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY_BASE64="replace-with-base64-encoded-private-key"
# FIREBASE_PRIVATE_KEY="replace-with-private-key-using-literal-newline-separators"

# NextAuth mode placeholders.
# FLOWBOARD_AUTH_MODE="nextauth"
# NEXT_PUBLIC_FLOWBOARD_AUTH_MODE="nextauth"
# Use the real app URL in deployment.
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="replace-with-a-random-nextauth-secret"
# GOOGLE_CLIENT_ID="replace-with-google-client-id"
# GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
# GITHUB_ID="replace-with-github-client-id"
# GITHUB_SECRET="replace-with-github-client-secret"

# Invite email delivery.
# Local/dev default prints emails to server logs.
# FLOWBOARD_EMAIL_PROVIDER="console"
#
# Optional production delivery via Resend.
# FLOWBOARD_EMAIL_PROVIDER="resend"
# FLOWBOARD_EMAIL_FROM="PlanGlade <invites@example.com>"
# RESEND_API_KEY="replace-with-resend-api-key"

# Maintenance job token for invite expiry endpoint.
# FLOWBOARD_MAINTENANCE_TOKEN="replace-with-random-maintenance-token"
