# Copy this file to .env for local development.
# Never commit .env. Keep real secrets, tokens, database URLs, and private keys out of git.

DATABASE_URL="file:../db/custom.db"

# Local development auth and storage.
# Do not use dev auth for a public/production deployment.
PLANGLADE_AUTH_MODE="dev"
NEXT_PUBLIC_PLANGLADE_AUTH_MODE="dev"
PLANGLADE_STORAGE_PROVIDER="local"
PLANGLADE_LOCAL_STORAGE_DIR="storage/local-attachments"
PLANGLADE_STORAGE_SIGNING_SECRET="replace-with-a-random-local-secret"

# Optional dev workspace seed labels.
PLANGLADE_WORKSPACE_SLUG="dev-workspace"
PLANGLADE_WORKSPACE_NAME="PlanGlade Dev Workspace"

# ---------------------------------------------------------------------------
# Docker Compose self-host baseline (the default quick start).
# ---------------------------------------------------------------------------
# The Docker default runs WITHOUT Firebase. It needs only:
#   - NextAuth (GitHub or Google OAuth)
#   - the SQLite volume (managed by docker-compose.yml)
#   - the local attachment volume (managed by docker-compose.yml)
# Replace every placeholder below before exposing the app outside your computer.
PLANGLADE_PORT="3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-nextauth-secret"
GITHUB_ID="replace-with-github-client-id"
GITHUB_SECRET="replace-with-github-client-secret"

# Local attachment storage signing secret.
# If unset, docker-compose.yml falls back to NEXTAUTH_SECRET. For stronger
# operational isolation, set a dedicated random value here.
# PLANGLADE_STORAGE_SIGNING_SECRET="replace-with-a-dedicated-random-secret"

# NextAuth mode placeholders (Docker already sets these via docker-compose.yml).
# PLANGLADE_AUTH_MODE="nextauth"
# NEXT_PUBLIC_PLANGLADE_AUTH_MODE="nextauth"
# Use the real app URL in deployment.
# GOOGLE_CLIENT_ID="replace-with-google-client-id"
# GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Invite email delivery.
# Local/dev default prints emails to server logs.
# PLANGLADE_EMAIL_PROVIDER="console"
#
# Optional production delivery via Resend.
# PLANGLADE_EMAIL_PROVIDER="resend"
# PLANGLADE_EMAIL_FROM="PlanGlade <invites@example.com>"
# RESEND_API_KEY="replace-with-resend-api-key"

# Maintenance job token for invite expiry endpoint.
# PLANGLADE_MAINTENANCE_TOKEN="replace-with-random-maintenance-token"

# ---------------------------------------------------------------------------
# OPTIONAL: Firebase Storage as a hosted/external attachment provider.
# ---------------------------------------------------------------------------
# Firebase is NOT required for Docker. Leave this section unset to keep using
# local file storage on the Docker attachment volume. Only set these if you
# intentionally switch PLANGLADE_STORAGE_PROVIDER (and, if you also use Firebase
# Auth, PLANGLADE_AUTH_MODE) to firebase.
# PLANGLADE_STORAGE_PROVIDER="firebase"
# PLANGLADE_AUTH_MODE="firebase"
# NEXT_PUBLIC_PLANGLADE_AUTH_MODE="firebase"
# NEXT_PUBLIC_FIREBASE_API_KEY="replace-with-public-firebase-api-key"
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="replace-with-sender-id"
# NEXT_PUBLIC_FIREBASE_APP_ID="replace-with-firebase-app-id"
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
# Use base64 for multiline private keys when possible.
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-placeholder@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY_BASE64="replace-with-base64-encoded-private-key"
# FIREBASE_PRIVATE_KEY="replace-with-private-key-using-literal-newline-separators"
