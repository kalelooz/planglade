// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  IN_REVIEW
  ON_HOLD
  ARCHIVED
}

enum WorkItemStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum WorkItemPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NoteVisibility {
  PRIVATE
  WORKSPACE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ActivityEntityType {
  WORKSPACE
  PROJECT
  WORK_ITEM
  NOTE
  COMMENT
}

enum ActivityActionType {
  CREATED
  UPDATED
  MOVED
  COMPLETED
  DELETED
  COMMENTED
  ASSIGNED
  UNASSIGNED
}

enum WorkItemRelationType {
  BLOCKS
  BLOCKED_BY
  RELATES_TO
  DUPLICATES
  PARENT_OF
  CHILD_OF
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  name              String?
  image             String?
  locale            String?
  timezone          String?
  memberships       WorkspaceMember[]
  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  createdProjects   Project[]         @relation("ProjectCreator")
  createdWorkItems  WorkItem[]        @relation("WorkItemCreator")
  assignedWorkItems WorkItem[]        @relation("WorkItemAssignee")
  createdNotes      Note[]            @relation("NoteCreator")
  updatedNotes      Note[]            @relation("NoteUpdater")
  comments          Comment[]
  attachments       Attachment[]
  createdViews      SavedView[]       @relation("ViewCreator")
  activityEvents    ActivityEvent[]   @relation("ActivityActor")
  settings          UserSettings[]
  invitesSent       WorkspaceInvite[] @relation("InviteSender")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Workspace {
  id            String            @id @default(cuid())
  slug          String            @unique
  name          String
  ownerId       String
  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships   WorkspaceMember[]
  projects      Project[]
  workItems     WorkItem[]
  labels        Label[]
  notes         Note[]
  views         SavedView[]
  activities    ActivityEvent[]
  settings      UserSettings[]
  invites       WorkspaceInvite[]
  comments      Comment[]
  attachments   Attachment[]
  workItemRelations WorkItemRelation[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Project {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  slug         String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  color        String?
  startDate    DateTime?
  dueDate      DateTime?
  archivedAt   DateTime?
  createdById  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  workItems    WorkItem[]
  notes        Note[]
  views        SavedView[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model WorkItem {
  id               String               @id @default(cuid())
  workspaceId      String
  projectId        String?
  title            String
  description      String?
  checklist        Json?
  noteIds          Json?
  status           WorkItemStatus       @default(BACKLOG)
  priority         WorkItemPriority     @default(MEDIUM)
  startDate        DateTime?
  dueDate          DateTime?
  completedAt      DateTime?
  sortOrder        Int                  @default(0)
  position         Float                @default(0)
  createdById      String
  assigneeId       String?
  parentId         String?
  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy        User                 @relation("WorkItemCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee         User?                @relation("WorkItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parent           WorkItem?            @relation("WorkItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children         WorkItem[]           @relation("WorkItemParent")
  labels           WorkItemLabel[]
  comments         Comment[]
  attachments      Attachment[]
  sourceRelations  WorkItemRelation[]   @relation("RelationSource")
  targetRelations  WorkItemRelation[]   @relation("RelationTarget")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([workspaceId, status])
  @@index([projectId, status])
  @@index([assigneeId, status])
}

model Label {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workItems   WorkItemLabel[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, name])
}

model WorkItemLabel {
  workItemId String
  labelId    String
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  label      Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([workItemId, labelId])
}

model Note {
  id            String         @id @default(cuid())
  workspaceId   String
  projectId     String?
  title         String
  body          String?
  visibility    NoteVisibility @default(PRIVATE)
  pinned        Boolean        @default(false)
  tags          Json?
  createdById   String
  updatedById   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy     User           @relation("NoteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy     User           @relation("NoteUpdater", fields: [updatedById], references: [id], onDelete: Restrict)
  attachments   Attachment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([workspaceId, pinned])
  @@index([projectId])
}

model SavedView {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  createdById String
  name        String
  layout      String
  groupBy     String?
  orderBy     String?
  filters     Json?
  display     Json?
  isDefault   Boolean  @default(false)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("ViewCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([projectId])
}

model UserSettings {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  theme       String?
  density     String?
  accent      String?
  notifications Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
}

model ActivityEvent {
  id          String             @id @default(cuid())
  workspaceId String
  actorId     String?
  action      ActivityActionType
  entityType  ActivityEntityType
  entityId    String
  summary     String?
  metadata    Json?
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User?              @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())

  @@index([workspaceId, createdAt])
}

model Comment {
  id          String    @id @default(cuid())
  workspaceId String
  workItemId  String
  authorId    String
  body        String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workItem    WorkItem  @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workItemId, createdAt])
}

model Attachment {
  id          String    @id @default(cuid())
  workspaceId String
  workItemId  String?
  noteId      String?
  uploadedById String
  name        String
  storageKey  String
  mimeType    String?
  sizeBytes   Int?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workItem    WorkItem? @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  note        Note?     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  uploadedBy  User      @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@index([workItemId])
  @@index([noteId])
}

model WorkItemRelation {
  id           String               @id @default(cuid())
  workspaceId  String
  sourceId     String
  targetId     String
  relationType WorkItemRelationType
  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source       WorkItem             @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       WorkItem             @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())

  @@unique([sourceId, targetId, relationType])
  @@index([workspaceId])
}

model WorkspaceInvite {
  id             String       @id @default(cuid())
  workspaceId    String
  email          String
  role           WorkspaceRole @default(MEMBER)
  token          String       @unique
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String
  acceptedById   String?
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy      User         @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([workspaceId, email])
}
